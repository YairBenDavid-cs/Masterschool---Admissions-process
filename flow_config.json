{
  "default_steps": [
    {
      "name": "personal_details",
      "display_name": "Personal Details Form",
      "tasks": ["submit_personal_details"]
    },
    {
      "name": "iq_test",
      "display_name": "IQ Test",
      "tasks": ["perform_iq_test"]
    },
    {
      "name": "interview",
      "display_name": "Interview",
      "tasks": ["schedule_interview", "perform_interview"]
    },
    {
      "name": "sign_contract",
      "display_name": "Sign Contract",
      "tasks": ["upload_identification_document", "sign_contract_task"]
    },
    {
      "name": "payment",
      "display_name": "Payment",
      "tasks": ["process_payment"]
    },
    {
      "name": "join_slack",
      "display_name": "Join Slack",
      "tasks": ["join_slack_task"]
    }
  ],
  "tasks_map": {
    "submit_personal_details": {
      "name": "submit_personal_details",
      "pass_condition_type": "AUTO_PASS",
      "payload_schema": [
        {"key_name": "first_name", "value_type": "str", "required": true, "description": "Applicant's first name", "example": "Jane"},
        {"key_name": "last_name",  "value_type": "str", "required": true, "description": "Applicant's last name",  "example": "Doe"},
        {"key_name": "email",      "value_type": "str", "required": true, "description": "Applicant's email address", "example": "jane.doe@example.com"},
        {"key_name": "timestamp",  "value_type": "int", "required": true, "description": "Unix timestamp of submission", "example": 1700000000}
      ],
      "transitions": [
        {
          "condition": "DEFAULT",
          "next_step": "iq_test",
          "next_task": "perform_iq_test"
        }
      ]
    },
    "perform_iq_test": {
      "name": "perform_iq_test",
      "pass_condition_type": "EVALUATE_PAYLOAD",
      "payload_schema": [
        {"key_name": "score",     "value_type": "int", "required": true, "description": "IQ test score (0-150)", "example": 85},
        {"key_name": "test_id",   "value_type": "str", "required": true, "description": "Unique identifier of the test session", "example": "test-001"},
        {"key_name": "timestamp", "value_type": "int", "required": true, "description": "Unix timestamp of test completion", "example": 1700000000}
      ],
      "transitions": [
        {
          "condition": "payload.get('score', 0) > 75",
          "next_step": "interview",
          "next_task": "schedule_interview"
        },
        {
          "condition": "payload.get('score', 0) >= 60 and payload.get('score', 0) <= 75",
          "next_step": "iq_test",
          "next_task": "second_chance_iq",
          "inject_to_custom_flow": true
        },
        {
          "condition": "DEFAULT",
          "next_step": "TERMINAL_REJECTED",
          "next_task": "NONE",
          "mark_status": "REJECTED"
        }
      ]
    },
    "second_chance_iq": {
      "name": "second_chance_iq",
      "pass_condition_type": "EVALUATE_PAYLOAD",
      "payload_schema": [
        {"key_name": "score", "value_type": "int", "required": true, "description": "Second-chance IQ test score (0-150)", "example": 80}
      ],
      "transitions": [
        {
          "condition": "payload.get('score', 0) > 75",
          "next_step": "interview",
          "next_task": "schedule_interview"
        },
        {
          "condition": "DEFAULT",
          "next_step": "TERMINAL_REJECTED",
          "next_task": "NONE",
          "mark_status": "REJECTED"
        }
      ]
    },
    "schedule_interview": {
      "name": "schedule_interview",
      "pass_condition_type": "AUTO_PASS",
      "payload_schema": [
        {"key_name": "interview_date", "value_type": "str", "required": true, "description": "Scheduled interview date (ISO 8601 format)", "example": "2025-06-01"}
      ],
      "transitions": [
        {
          "condition": "DEFAULT",
          "next_step": "interview",
          "next_task": "perform_interview"
        }
      ]
    },
    "perform_interview": {
      "name": "perform_interview",
      "pass_condition_type": "EVALUATE_PAYLOAD",
      "payload_schema": [
        {"key_name": "decision",      "value_type": "str", "required": true, "description": "Interview outcome", "example": "passed_interview", "allowed_values": ["passed_interview", "failed_interview"]},
        {"key_name": "interview_date","value_type": "str", "required": true, "description": "Date the interview was conducted (ISO 8601 format)", "example": "2025-06-01"},
        {"key_name": "interviewer_id","value_type": "str", "required": true, "description": "Unique identifier of the interviewer", "example": "int-001"}
      ],
      "transitions": [
        {
          "condition": "payload.get('decision') == 'passed_interview'",
          "next_step": "sign_contract",
          "next_task": "upload_identification_document"
        },
        {
          "condition": "payload.get('decision') == 'failed_interview'",
          "next_step": "TERMINAL_REJECTED",
          "next_task": "NONE",
          "mark_status": "REJECTED"
        },
        {
          "condition": "DEFAULT",
          "next_step": "TERMINAL_REJECTED",
          "next_task": "NONE",
          "mark_status": "REJECTED"
        }
      ]
    },
    "upload_identification_document": {
      "name": "upload_identification_document",
      "pass_condition_type": "AUTO_PASS",
      "payload_schema": [
        {"key_name": "passport_number", "value_type": "str", "required": true, "description": "Applicant's passport number", "example": "AB123456"},
        {"key_name": "timestamp",       "value_type": "int", "required": true, "description": "Unix timestamp of document upload", "example": 1700000000}
      ],
      "transitions": [
        {
          "condition": "DEFAULT",
          "next_step": "sign_contract",
          "next_task": "sign_contract_task"
        }
      ]
    },
    "sign_contract_task": {
      "name": "sign_contract_task",
      "pass_condition_type": "AUTO_PASS",
      "payload_schema": [
        {"key_name": "timestamp", "value_type": "int", "required": true, "description": "Unix timestamp of contract signing", "example": 1700000000}
      ],
      "transitions": [
        {
          "condition": "DEFAULT",
          "next_step": "payment",
          "next_task": "process_payment"
        }
      ]
    },
    "process_payment": {
      "name": "process_payment",
      "pass_condition_type": "AUTO_PASS",
      "payload_schema": [
        {"key_name": "payment_id", "value_type": "str", "required": true, "description": "Unique payment transaction identifier", "example": "pay-001"},
        {"key_name": "timestamp",  "value_type": "int", "required": true, "description": "Unix timestamp of payment completion", "example": 1700000000}
      ],
      "transitions": [
        {
          "condition": "DEFAULT",
          "next_step": "join_slack",
          "next_task": "join_slack_task"
        }
      ]
    },
    "join_slack_task": {
      "name": "join_slack_task",
      "pass_condition_type": "AUTO_PASS",
      "payload_schema": [
        {"key_name": "email",     "value_type": "str", "required": true, "description": "Email address used to join the Slack workspace", "example": "jane.doe@example.com"},
        {"key_name": "timestamp", "value_type": "int", "required": true, "description": "Unix timestamp of Slack join event", "example": 1700000000}
      ],
      "transitions": [
        {
          "condition": "DEFAULT",
          "next_step": "TERMINAL_ACCEPTED",
          "next_task": "NONE",
          "mark_status": "ACCEPTED"
        }
      ]
    }
  }
}
